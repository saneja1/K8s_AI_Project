# Example environment variables
# Copy this to .env and fill in your values (do not commit .env)

# SSH Configuration
SSH_PORT=22
SSH_USERNAME=
SSH_PASSWORD=
SSH_KEY_PATH=

# Minimum Requirements
MIN_CPU_CORES=2
MIN_MEMORY_MIB=4096
MIN_DISK_GIB=30

# AI Assistant Configuration
# Gemini API - Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# Claude API - Get your key from: https://console.anthropic.com/
# Used when selecting "Claude (Anthropic)" in the LLM selector
ANTHROPIC_API_KEY=
